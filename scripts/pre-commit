#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

"$ROOT/scripts/update-lessons-index.sh"

if ! git diff --quiet -- curriculum/lessons/main/index.json 2>/dev/null; then
  git add curriculum/lessons/main/index.json
  echo "pre-commit: staged curriculum/lessons/main/index.json"
fi
